# docker-homelab
MAIN_NAME=homelab

# versions
TRAEFIK_VERSION=latest
ADMINER_VERSION=latest
GITEA_VERSION=latest
PORTAINER_VERSION=latest
QB_VERSION=latest
HEIMDALL_VERSION=latest


# host-names
TRAEFIK_HOST=traefik.localhost
ADMINER_HOST=adminer.localhost
GITEA_HOST=gitea.localhost
PORTAINER_HOST=portainer.localhost
QB_HOST=qbittorrent.localhost
HEIMDALL_HOST=home.localhost


# Gitea
GITEA_URL=https://gitea.localhost
GITEA_HOSTNAME=gitea.localhost

# Postgresql 
DB_TYPE=postgres
DB_NAME=gitea
DB_PASSWD=gitea
DB_USER=gitea