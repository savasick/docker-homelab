# docker-homelab
MAIN_NAME=homelab

# versions
TRAEFIK_VERSION=latest
ADMINER_VERSION=latest
GITEA_VERSION=latest
PORTAINER_VERSION=latest
QB_VERSION=latest
DASHY_VERSION=latest

# urls
ADMINER_URL=`adminer.localhost`

GITEA_URL=`gitea.localhost`

PORTAINER_URL=`portainer.localhost`

QB_URL=`qbittorrent.localhost`

DASHY_URL=`home.localhost`



# Gitea
GITEA_URL=https://gitea.localhost
GITEA_HOSTNAME=gitea.localhost

# Postgresql 
DB_TYPE=postgres
DB_NAME=gitea
DB_PASSWD=gitea
DB_USER=gitea